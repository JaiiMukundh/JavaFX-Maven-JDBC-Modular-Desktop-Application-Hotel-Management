<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotelmanagement.controller.CustomerController"
            fitToWidth="true" fitToHeight="true">
    <VBox fx:id="customerManagementVBox" styleClass="page-shell" fillWidth="true">
        <VBox styleClass="section-card">
            <VBox spacing="4">
                <Label text="Add Customer" styleClass="section-title"/>
                <Label text="Enter customer information."
                       styleClass="section-subtitle"/>
            </VBox>

            <GridPane hgap="10" vgap="10">
                <Label text="Customer Name" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="customerNameField" prefWidth="220" promptText="Enter full name"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Contact Number" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="contactNumberField" prefWidth="220" promptText="10-digit mobile number"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Preferred Room Number (Optional)" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <ComboBox fx:id="selectedRoomCombo" prefWidth="220" promptText="Leave blank if not assigned"
                          GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Button fx:id="addCustomerBtn" text="Add Customer" styleClass="btn-primary"
                        GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            </GridPane>
        </VBox>

        <VBox styleClass="section-card" VBox.vgrow="ALWAYS">
            <HBox styleClass="toolbar">
                <Label text="Customers" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchCustomerField" prefWidth="240"
                           promptText="Search customer by name"/>
                <Button fx:id="refreshCustomerBtn" text="Refresh"
                        styleClass="btn-outline-primary"/>
                <Button fx:id="deleteCustomerBtn" text="Delete Customer"
                        styleClass="btn-danger"/>
            </HBox>

            <Label text="Customer booking details."
                   styleClass="section-subtitle"/>

            <TableView fx:id="customerTableView" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn text="Customer ID" prefWidth="130"/>
                    <TableColumn text="Name" prefWidth="180"/>
                    <TableColumn text="Contact Number" prefWidth="170"/>
                    <TableColumn text="Preferred Room Number" prefWidth="170"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>
